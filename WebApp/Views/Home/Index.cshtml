@model IReadOnlyList<WebApp.Models.TDanhMucSp>

@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LayoutEcomm.cshtml";
}

<div class="content_top">
    <div class="wrap">
        <h3>Sản phẩm Vali</h3>
    </div>
    <div class="line"> </div>
    <div class="wrap">
        <div class="section group">
            @if (Model?.Count > 0)
            {
                foreach (var item in Model)
                {
                    <div class="grid_1_of_4 images_1_of_4">
                        <h4><a href="#">@item.TenSp</a></h4>
                        <a href="#">
                            <img src="@(Url.Content("~/vali/images/" + item.AnhDaiDien))" alt="@item.TenSp" />
                        </a>
                        <div class="price-details">
                            <div class="price-number">
                                <p><span class="rupees">@item.GiaNhoNhat?.ToString("N0")</span></p>
                            </div>
                            <div class="add-cart">
                                <h4><a href="#">More Info</a></h4>
                            </div>
                            <div class="clear"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>Chưa có sản phẩm vali.</p>
            }
        </div>
    </div>
</div>
